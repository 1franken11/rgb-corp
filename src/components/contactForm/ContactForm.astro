---
import { getLanguageFromURL } from '../../i18n/utils';
import type { Language } from '../../i18n/utils';
import './ContactForm.css';

interface Props {
  lang?: Language;
}

const { lang } = Astro.props;
const currentLang = lang || getLanguageFromURL(Astro.url.pathname);

const translations = {
  es: {
    title: "Contáctanos",
    subtitle: "Estamos aquí para ayudarte",
    name: "Nombre",
    surname: "Apellido",
    email: "Correo electrónico",
    phone: "Teléfono",
    message: "Mensaje",
    submit: "Enviar",
    success: "¡Mensaje enviado con éxito!",
    error: "Error al enviar el mensaje. Por favor, inténtalo de nuevo.",
    before: "Antes",
    after: "Después"
  },
  en: {
    title: "Contact Us",
    subtitle: "We're here to help",
    name: "Name",
    surname: "Surname",
    email: "Email",
    phone: "Phone",
    message: "Message",
    submit: "Submit",
    success: "Message sent successfully!",
    error: "Error sending message. Please try again.",
    before: "Before",
    after: "After"
  },
  pt: {
    title: "Contate-nos",
    subtitle: "Estamos aqui para ajudar",
    name: "Nome",
    surname: "Sobrenome",
    email: "Email",
    phone: "Telefone",
    message: "Mensagem",
    submit: "Enviar",
    success: "Mensagem enviada com sucesso!",
    error: "Erro ao enviar mensagem. Por favor, tente novamente.",
    before: "Antes",
    after: "Depois"
  }
};

const t = translations[currentLang];

const comparisons = [
  {
    before: "/images/comparison1-before.jpg",
    after: "/images/comparison1-after.jpg"
  },
  {
    before: "/images/comparison2-before.jpg",
    after: "/images/comparison2-after.jpg"
  }
];
---

<section class="contact-container">
  <div class="contact-info">
    <h2>{t.title}</h2>
    <p>{t.subtitle}</p>
    <div class="social-icons">
      <a href="https://instagram.com/rgbcorp" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-instagram icon instagram"></i>
      </a>
      <a href="https://facebook.com/rgbcorp" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-facebook icon facebook"></i>
      </a>
      <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-whatsapp icon whatsapp"></i>
      </a>
    </div>
  </div>

  <div class="contact-form">
    <form id="contactForm">
      <div>
        <label for="name">{t.name}</label>
        <input type="text" id="name" name="name" required />
      </div>
      <div>
        <label for="surname">{t.surname}</label>
        <input type="text" id="surname" name="surname" required />
      </div>
      <div>
        <label for="email">{t.email}</label>
        <input type="email" id="email" name="email" required />
      </div>
      <div>
        <label for="phone">{t.phone}</label>
        <input type="tel" id="phone" name="phone" required />
      </div>
      <div>
        <label for="message">{t.message}</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <button type="submit">{t.submit}</button>
    </form>
    <div id="successMessage" class="success-message hidden">{t.success}</div>
    <div id="errorMessage" class="error-message hidden">{t.error}</div>
  </div>
</section>

<div class="image-comparison-section">
  {comparisons.map((comparison) => (
    <div class="comparison-item">
      <div>
        <h3>{t.before}</h3>
        <img src={comparison.before} alt="Before" />
      </div>
      <div>
        <h3>{t.after}</h3>
        <img src={comparison.after} alt="After" />
      </div>
    </div>
  ))}
</div>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const successMessage = document.getElementById('successMessage');
  const errorMessage = document.getElementById('errorMessage');

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Aquí irá la lógica de EmailJS cuando se configure
      console.log('Form submitted');
      
      if (successMessage) {
        successMessage.classList.remove('hidden');
        setTimeout(() => {
          successMessage.classList.add('hidden');
        }, 5000);
      }

      form.reset();
    });
  }
</script> 