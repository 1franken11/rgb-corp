---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import './ProjectSections.css';

interface Props {
  lang?: string;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const projects = [
  {
    media: '/images/projects/project1.jpg',
    gallery: [
      '/images/projects/project1-1.jpg',
      '/images/projects/project1-2.jpg',
      '/images/projects/project1-3.jpg'
    ]
  },
  {
    media: '/images/projects/project2.jpg',
    gallery: [
      '/images/projects/project2-1.jpg',
      '/images/projects/project2-2.jpg',
      '/images/projects/project2-3.jpg'
    ]
  },
  {
    media: '/images/projects/project3.jpg',
    gallery: [
      '/images/projects/project3-1.jpg',
      '/images/projects/project3-2.jpg',
      '/images/projects/project3-3.jpg'
    ]
  }
];
---

<section class="project-section">
  <h2 class="project-title">{t('ProjectSection.title')}</h2>
  <div class="project-grid">
    {projects.map((project, index) => (
      <div class="project-item" data-index={index}>
        <img src={project.media} alt={`Project ${index + 1}`} loading="lazy" />
        <div class="project-overlay">
          <button class="view-gallery-btn" data-gallery={JSON.stringify(project.gallery)}>
            {t('ProjectSection.viewGallery')}
          </button>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // Manejar la apertura de la galería
  document.querySelectorAll('.view-gallery-btn').forEach(button => {
    button.addEventListener('click', (e) => {
      const gallery = JSON.parse(button.getAttribute('data-gallery') || '[]');
      const modal = document.createElement('project-modal');
      modal.setAttribute('gallery', JSON.stringify(gallery));
      document.body.appendChild(modal);
    });
  });

  // Precargar imágenes
  const preloadImages = () => {
    const images = document.querySelectorAll('.project-item img');
    images.forEach(img => {
      if ('loading' in HTMLImageElement.prototype) {
        img.setAttribute('loading', 'lazy');
      } else {
        // Fallback para navegadores que no soportan lazy loading
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const img = entry.target as HTMLImageElement;
              img.src = img.dataset.src || '';
              observer.unobserve(img);
            }
          });
        });
        observer.observe(img);
      }
    });
  };

  // Inicializar precarga de imágenes
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', preloadImages);
  } else {
    preloadImages();
  }
</script> 