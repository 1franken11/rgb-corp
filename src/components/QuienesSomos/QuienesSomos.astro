---
import { getLangFromUrl, useTranslations, type Language } from '../../i18n/utils.ts';
import './QuienesSomos.css';

interface Props {
  lang?: Language;
}

const { lang: propLang } = Astro.props;
const currentLang: Language = propLang || getLangFromUrl(Astro.url).lang;
const t = useTranslations(currentLang);

const specialtyTitle = t('QuienesSomos.specialty.title');
const specialtyDescription = t('QuienesSomos.specialty.description');
const whyChooseUsTitle = t('QuienesSomos.whyChooseUs.title');
const whyChooseUsItems = t('QuienesSomos.whyChooseUs.items');
const commitmentTitle = t('QuienesSomos.commitment.title');
const commitmentDescription = t('QuienesSomos.commitment.description');
const servicesTitle = t('QuienesSomos.services.title');
const servicesDescription = t('QuienesSomos.services.description');
const floorTypesTitle = t('QuienesSomos.floorTypes.title');
const floorTypes = t('QuienesSomos.floorTypes.items');
const cabinetsTitle = t('QuienesSomos.cabinets.title');
const cabinets = t('QuienesSomos.cabinets.items');
const materialsTitle = t('QuienesSomos.materials.title');
const materials = t('QuienesSomos.materials.items');
---

<section id="quienes-somos" class="quienes-somos" data-aos="fade-up">

  
  <div class="container">
    <div class="specialty" data-aos="fade-right" data-aos-delay="200">
      
    <div class="services" data-aos="fade-up" data-aos-delay="300">
      <h2>{servicesTitle}</h2>
      <ul>
        {Array.isArray(servicesDescription) && servicesDescription.map((service) => (
          <li data-aos="fade-left" data-aos-delay="400">{service}</li>
        ))}
      </ul>
    </div>

      <h2 data-aos="fade-up" data-aos-delay="100">{specialtyTitle}</h2>
      <p data-aos="fade-up" data-aos-delay="150">{specialtyDescription}</p>

    <div class="why-choose-us" data-aos="fade-up" data-aos-delay="250">
      <ul>
        {Array.isArray(whyChooseUsItems) && whyChooseUsItems.map((item, index) => (
          <li data-aos="fade-left" data-aos-delay={300 + index * 50}>{item}</li>
        ))}
      </ul>
    </div>
    </div>


    <div class="commitment" data-aos="fade-left" data-aos-delay="200">
      <h2 data-aos="fade-up" data-aos-delay="100">{commitmentTitle}</h2>
      <div class="commitment-items">
        {Array.isArray(commitmentDescription) && commitmentDescription.map((item, index) => (
          <div class="commitment-item" data-aos="fade-up" data-aos-delay={200 + index * 100}>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section> 