---
import MainLayout from '../../layouts/MainLayout.astro';
import type { Language } from '../../i18n/utils';
import FirstSection from '../../components/FirstSection/FirstSection.astro';
import { QuienesSomos } from '@/components';
import {FlooringSection} from '@/components';
import {ImageComparison} from '@/components';
import ProjectSection from '../../components/ProjectSection/ProjectSection.astro';
import {OpinionesCarousel} from '@/components';
import {ContactForm, ShadersSliderMultilingual} from '@/components';
import Footer from '@/components/layout/Footer.astro';
const lang: Language = 'pt';

---

<MainLayout title="Home | RGB Corp" lang={lang}>
    <main>
  <ShadersSliderMultilingual lang={lang} />
  <QuienesSomos lang={lang} />
  <FlooringSection lang={lang} />
  <ProjectSection lang={lang} />
  <OpinionesCarousel lang={lang} />
  <ContactForm lang={lang} />
  <Footer lang={lang} />

  </main>
</MainLayout> 