---
import { getLangFromUrl, useTranslations, type Language } from '../../i18n/utils.ts';

interface Props {
  lang?: Language;
}

const { lang: propLang } = Astro.props;
// Aseguramos que currentLang siempre sea de tipo Language, asumiendo que getLangFromUrl devuelve directamente un Language
const currentLang: Language = (propLang || getLangFromUrl(Astro.url)) as Language; // <-- Cambio importante aquí
const t = useTranslations(currentLang);

const floors = [
  { 
    key: "Vinyl", 
    label: t('FlooringSections.options.Vinyl'), 
    image: "https://res.cloudinary.com/drwacbtjf/image/upload/v1743508300/WhatsApp_Image_2025-03-31_at_23.10.44_ff4b6490_phzxzy.jpg", 
    bgImage: "https://res.cloudinary.com/drwacbtjf/image/upload/v1744642268/vynil_sie1yd.jpg" 
  },
  { 
    key: "Laminate", 
    label: t('FlooringSections.options.Laminate'), 
    image: "https://res.cloudinary.com/drwacbtjf/image/upload/v1743508301/WhatsApp_Image_2025-03-31_at_23.10.44_86077beb_mnfxib.jpg", 
    bgImage: "https://res.cloudinary.com/drwacbtjf/image/upload/v1744642091/laminate_1_ewkfrn.jpg" 
  },
  { 
    key: "Tile", 
    label: t('FlooringSections.options.Tile'), 
    image: "https://res.cloudinary.com/drwacbtjf/image/upload/v1743508301/WhatsApp_Image_2025-03-31_at_23.10.45_7e4276ce_gettwe.jpg", 
    bgImage: "https://res.cloudinary.com/drwacbtjf/image/upload/v1744642267/Tile_tbbln5.jpg" 
  },
  { 
    key: "Wood", 
    label: t('FlooringSections.options.Wood'), 
    image: "https://res.cloudinary.com/drwacbtjf/image/upload/v1743508300/WhatsApp_Image_2025-03-31_at_23.10.44_3f250b6b_g2xic4.jpg", 
    bgImage: "https://res.cloudinary.com/drwacbtjf/image/upload/v1744642270/wood_kctkbz.jpg" 
  }
];
---

<div class="flooring-grid">
  {floors.map((floor) => (
    <div
      class="flooring-card"
      data-floor={floor.key}
      data-bg-image={floor.bgImage}
    >
      <img src={floor.image} alt={floor.label} loading="lazy" />
      <div class="floor-label">{floor.label}</div>
    </div>
  ))}
</div>

<script>
  const flooringCards = document.querySelectorAll('.flooring-card');

  flooringCards.forEach(card => {
    card.addEventListener('click', () => {
      const floor = card.getAttribute('data-floor');
      const bgImage = card.getAttribute('data-bg-image');
      if (floor && bgImage) {
        document.dispatchEvent(new CustomEvent('floorSelected', {
          detail: { floor, bgImage }
        }));
      }
    });

    card.addEventListener('mouseenter', () => {
      const bgImage = card.getAttribute('data-bg-image');
      if (bgImage) {
        document.dispatchEvent(new CustomEvent('floorHover', {
          detail: { bgImage }
        }));
      }
    });

    card.addEventListener('mouseleave', () => {
      document.dispatchEvent(new CustomEvent('floorLeave'));
    });
  });
</script> 