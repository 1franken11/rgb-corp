---
import MainLayout from '../layouts/MainLayout.astro';
import TopBar from '../components/common/topbar/TopBar.astro';
import Navbar from '../components/common/navbar/Navbar.astro';
import LanguageSelector from '../components/languageSelector/LanguageSelector.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

// Redirigir a la versión en español por defecto
Astro.redirect('/es/');

const { lang } = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout title="RGB Corporation - Inicio" lang={lang}>
  <TopBar client:load />
  <Navbar lang={lang} />
  <LanguageSelector currentLang={lang} currentPath={Astro.url.pathname} />
  <div class="container">
    <h1>{t('home.title')}</h1>
    <p>{t('home.description')}</p>
  </div>
</MainLayout>
