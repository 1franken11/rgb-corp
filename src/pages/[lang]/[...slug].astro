---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, type Language } from '../../i18n/utils';
import { languages } from '../../i18n/utils';

export async function getStaticPaths() {
  const pages = ['about', 'services', 'contact', 'privacy-policy'];
  const paths = [];

  for (const lang of Object.keys(languages)) {
    for (const page of pages) {
      paths.push({
        params: { lang, slug: page },
        props: { lang: lang as Language, page }
      });
    }
  }

  return paths;
}

const { lang, page } = Astro.props;
const t = useTranslations(lang);

// Mapeo de páginas a componentes
const pageComponents = {
  'about': () => import('../../components/QuienesSomos/QuienesSomos.astro'),
  'services': () => import('../../components/Services/Services.astro'),
  'contact': () => import('../../components/Contact/Contact.astro'),
  'privacy-policy': () => import('../../components/PrivacyPolicy/PrivacyPolicy.astro')
};

const module = await pageComponents[page as keyof typeof pageComponents]();
const Component = module.default;
---

<Layout title={t(`${page}.title`)} description={t(`${page}.description`)}>
  <main>
    <Component lang={lang} />
  </main>
</Layout>