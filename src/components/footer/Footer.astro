---
import styles from './Footer.module.css';
---

<footer class={styles.footer} role="contentinfo">
  <div class={styles.footerLeft}>
    <div class={styles.socialLinks}>
      <a
        href="https://www.instagram.com/rgb_corp/"
        target="_blank"
        rel="noopener noreferrer"
        class={styles.socialLink}
        aria-label="Follow us on Instagram"
      >
        <i class="fab fa-instagram"></i>
      </a>
      <a
        href="https://www.facebook.com/profile.php?id=61562097362152"
        target="_blank"
        rel="noopener noreferrer"
        class={styles.socialLink}
        aria-label="Follow us on Facebook"
      >
        <i class="fab fa-facebook"></i>
      </a>
      <a
        href="https://wa.me/+19044225380"
        target="_blank"
        rel="noopener noreferrer"
        class={styles.socialLink}
        aria-label="Contact us on WhatsApp"
      >
        <i class="fab fa-whatsapp"></i>
      </a>
    </div>
    <span class={styles.copyright}>
      ©{new Date().getFullYear()} RGB Corporation
    </span>
  </div>

  <div class={styles.footerRight}>
    <span class={styles.credit}>Designed by Franco Garcia</span>
  </div>
</footer> 