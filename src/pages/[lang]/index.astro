---
import MainLayout from '../../layouts/MainLayout.astro';
import FirstSection from '../../components/FirstSection/FirstSection.astro';
import QuienesSomos from '../../components/QuienesSomos/QuienesSomos.astro';
import FlooringSection from '../../components/flooringSection/FlooringSection.astro';
import ProjectSection from '../../components/ProjectSection/ProjectSection.astro';
import OpinionesCarousel from '../../components/opinionesCarousel/OpinionesCarousel.astro';
import ContactForm from '../../components/contactForm/ContactForm.astro';
import Footer from '../../components/layout/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const { lang } = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout title={t('Menu.home')} lang={lang}>
  <main>
    <FirstSection lang={lang} />
    <QuienesSomos lang={lang} />
    <FlooringSection client:load lang={lang} />
    <ProjectSection client:load lang={lang} />
    <OpinionesCarousel client:load lang={lang} />
    <ContactForm lang={lang} client:visible />
    <Footer client:visible />
  </main>
</MainLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  p {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  main {
    min-height: 100vh;
    padding: 2rem 0;
  }
</style> 