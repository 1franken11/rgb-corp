---
import MainLayout from '../../layouts/MainLayout.astro';
import TopBar from '../../components/common/topbar/TopBar.astro';
import Navbar from '../../components/common/navbar/Navbar.astro';
import LanguageSelector from '../../components/languageSelector/LanguageSelector.astro';
import FlooringSection from '../../components/flooringSection/FlooringSection.astro';
import ProjectSection from '../../components/projectSection/ProjectSection.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const { lang } = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout title={t('Menu.home')} lang={lang}>
  <TopBar client:load lang={lang} />
  <Navbar client:load lang={lang} />
  <LanguageSelector client:load lang={lang} />
  
  <main>
    <FlooringSection client:load lang={lang} />
    <ProjectSection client:load lang={lang} />
    <OpinionesCarousel client:load lang={lang} />
  </main>
</MainLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  p {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  main {
    min-height: 100vh;
    padding: 2rem 0;
  }
</style> 