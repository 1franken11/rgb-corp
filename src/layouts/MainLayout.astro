---
// import '../styles/global.css';
import TopBar from '../components/common/topbar/TopBar.astro';
import Navbar from '../components/common/navbar/Navbar.astro';
import type { Language } from '../i18n/utils';
import { getLangFromUrl } from '../i18n/utils';
import { getSeoData } from '../utils/seo';

const url = new URL(Astro.request.url);
const { lang } = getLangFromUrl(url);
const seo = getSeoData(lang, url.pathname);
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <meta name="generator" content={Astro.generator} />

<!-- SEO Metadata -->
    <meta name="description" content={seo.description} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />
    <link rel="canonical" href={`https://rgb-corporation.com/${lang}${url.pathname}`} />
    <title>{seo.title}</title>

    <!-- Fonts and CSS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    
    <!-- AOS CSS -->
    <!-- <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" /> -->

    <!-- Vercel Analytics -->
    <!-- <script async src="/_vercel/insights/script.js"></script> -->
  </head>
  <body>
    <Navbar client:load />
    <slot />
    
    <!-- AOS JS -->
    <!-- <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script is:inline>
      // Configuración global de AOS
      document.addEventListener('DOMContentLoaded', function() {
        // Esperar un poco para asegurar que AOS esté cargado
        setTimeout(() => {
          if (window.AOS) {
            window.AOS.init({
              duration: 1000,
              once: true,
              mirror: false,
              offset: 100,
              easing: 'ease-in-out'
            });
          }
        }, 100);
      });
    </script> -->
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #8bbaca;
    --color-secondary: #ffffff;
    --color-accent: #4a90e2;
    --color-text: #333333;
    --color-background: #ffffff;
    --color-black: #000000;
    --spacing-xs: 0.5rem;
    --spacing-sm: 1rem;
    --spacing-md: 1.5rem;
    --spacing-lg: 2rem;
    --navbar-height: 100px;
    --topbar-height: 36px;
    --header-total-height: calc(var(--navbar-height) + var(--topbar-height));
  }

  @media (max-width: 768px) {
    :root {
      --navbar-height: 80px;
      --topbar-height: 32px;
    }
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    margin: 0;
    width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-style: normal;
    transform: none !important;
    overflow: visible !important;
    box-sizing: border-box;
  }

  body {
    margin: 0;
    width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-style: normal;
    transform: none !important;
    overflow: visible !important;
    padding-top: 0;
    box-sizing: border-box;
    background-color: #ffffff;
    min-height: 100vh;
  }

  p, ul, li {
    text-align: justify;
  }

  h2 {
    font-size: 2.2rem;
    color: var(--color-primary);
  }

  /* AOS Animations */
  /* [data-aos] {
    pointer-events: none;
  }
  [data-aos].aos-animate {
    pointer-events: auto;
  } */

  /* Debug: asegurar que el contenido sea visible */
  main {
    position: relative;
    z-index: 1;
    background-color: #ffffff;
    margin-top: 140px; /* Ajustado para coincidir con la altura real del navbar */
  }

  section {
    position: relative;
    z-index: 1;
  }

  /* Asegurar que el navbar no cubra el contenido */
  .navbar {
    z-index: 1000;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    overflow: visible !important;
  }

  /* Asegurar que el contenido esté debajo del navbar */
  .navbar + * {
    margin-top: 140px;
  }

  /* Asegurar que el body no tenga transformaciones */
  body {
    transform: none !important;
    overflow: visible !important;
  }
</style>