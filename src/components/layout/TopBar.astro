---
// Importamos los datos de idiomas
const languages = [
  { code: 'es', name: 'Español', flag: '/flag/ES.png' },
  { code: 'en', name: 'English', flag: '/flag/EN.png' },
  { code: 'por', name: 'Português', flag: '/flag/POR.png' }
];
---

<div class="topbar">
  <div class="container">
    <div class="contact-info">
      <a href="tel:+1234567890" class="phone">
        <i class="fas fa-phone"></i> +1 (234) 567-890
      </a>
      <a href="mailto:info@rgbcorp.com" class="email">
        <i class="fas fa-envelope"></i> info@rgbcorp.com
      </a>
    </div>
    <div class="language-selector">
      {languages.map((lang) => (
        <a href={`?lang=${lang.code}`} class="lang-option">
          <img src={lang.flag} alt={lang.name} width="20" height="15" />
          <span>{lang.name}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .topbar {
    background-color: var(--color-primary);
    color: var(--color-secondary);
    padding: var(--spacing-xs) 0;
    font-size: 0.9rem;
  }

  .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .contact-info {
    display: flex;
    gap: var(--spacing-md);
  }

  .contact-info a {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-secondary);
    transition: opacity 0.3s ease;
  }

  .contact-info a:hover {
    opacity: 0.8;
  }

  .language-selector {
    display: flex;
    gap: var(--spacing-sm);
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .lang-option:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .lang-option img {
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .container {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .contact-info {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .language-selector {
      width: 100%;
      justify-content: center;
    }
  }
</style> 