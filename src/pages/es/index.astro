---
import MainLayout from '../../layouts/MainLayout.astro';
import type { Language } from '../../i18n/utils';
import FirstSection from '../../components/FirstSection/FirstSection.tsx';
import QuienesSomos from '../../components/QuienesSomos/QuienesSomos.astro';
import FlooringSection from '../../components/flooringSection/FlooringSection.astro';
import ProjectSection from '../../components/ProjectSection/ProjectSection.astro';
import OpinionesCarousel from '../../components/opinionesCarousel/OpinionesCarousel.astro';
import ContactForm from '../../components/contactForm/ContactForm.astro';
import Footer from '@/components/layout/Footer.astro';
import '../../components/FirstSection/fullpage.css';
import ShadersSlider from '@/components/ShadersSlider/ShadersSlider.astro';

const lang: Language = 'es';


---

<MainLayout title="RGB Corporation - Inicio" lang={lang}>
    <main>
  <FirstSection client:only="react" lang={lang} />
  <ShadersSlider />
  <QuienesSomos lang={lang} />
  <FlooringSection lang={lang} />
  <ProjectSection lang={lang} />
  <OpinionesCarousel lang={lang} client:visible />
  <ContactForm lang={lang} client:visible />
  <Footer lang={lang} client:visible />

  </main>
</MainLayout> 